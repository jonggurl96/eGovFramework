<%@ taglib uri="http://www.springframework.org/tags" prefix="spring" %>




<div class="login-info-box" style="border:solid;border-color:#ffff99;width:100%;overflow:hidden">
	<div class="login-info" style="float:left;padding:3px">
		<img src="/images/test/user/profile.jpg" style="border-radius:50%;width:36px;height:36px">
		<strong id="login-id">${loginInfo.id }</strong>
	</div>
	<!-- /.login-info -->
	<div class="logout-button" style="float:right">
		<form action="/user/logout">
			<button style="margin:10px"><spring:message code="label.logout"/></button>
		</form>
	</div>
	<!-- /.logout-button -->
</div>
<!-- /.login-info-box -->
